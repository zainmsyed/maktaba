    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "pdfjs-dist": "4.4.168",
    "svelte-pdf-highlighter": "^0.2.3"
